# PathFinder Lite public demo defaults
ENVIRONMENT=production
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=
PUBLIC_API_URL=
RATE_LIMIT=10

# Default runtime for public launch.
# DeepSeek is the recommended API provider for the first public demo.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional OpenAI-compatible fallback. Keep unset unless you choose Qwen.
QWEN_API_KEY=
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# Optional local fallback.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b

# Optional deep research provider. The bundled public demos do not require it.
TAVILY_API_KEY=

# Keep costly LLM second-pass reviewers off by default for public demo latency.
ENABLE_LLM_ADVISORS=0
ENABLE_LLM_CRITIC=0

# Public demo controls.
VITE_SHOW_ADMISSIONS_DEMO=true
VITE_BASE_PATH=/app/
VITE_API_URL=
