# ============================================
# GaokaoAgent 环境变量配置示例
# ============================================

# === 环境配置 ===
# 可选值：development（开发）或 production（生产）
ENVIRONMENT=development

# === API 服务器配置 ===
# API服务器监听地址（生产环境建议127.0.0.1，不建议0.0.0.0）
API_HOST=127.0.0.1
# API服务器端口
API_PORT=8000

# === CORS 配置 ===
# 生产环境前端URL（用于CORS白名单）
# 示例：https://gaokaoagent.example.com
FRONTEND_URL=

# === 速率限制配置 ===
# 每分钟允许的请求数（默认：10）
RATE_LIMIT=10

# === LLM 提供商选择 ===
# 可选值：cloud（云端）或 local（本地）
LLM_PROVIDER=local

# === 云端模式配置（阿里云 Qwen）===
# 如果 LLM_PROVIDER=cloud，需要配置以下变量
QWEN_API_KEY=your_qwen_api_key_here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# === 本地模式配置（Ollama）===
# 如果 LLM_PROVIDER=local，需要配置以下变量
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# === Optional LLM audit hooks ===
# Keep these off by default for cost and latency. Turn them on when you want
# advisor agents and critic to run a structured LLM second-pass critique.
ENABLE_LLM_ADVISORS=0
ENABLE_LLM_CRITIC=0

# === 搜索 API 配置 ===
# Tavily Search API（用于 Deep Research 慢思考循环）
# 获取 API Key: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# === 多模态模型配置（本地）===
# Ollama Vision 模型（用于 PDF/图像解析）
VISION_MODEL=llava:7b

# === LangGraph 配置（可选）===
# 这些值会覆盖 configuration.py 中的默认值

# 初始搜索查询数量（默认：3）
# NUMBER_OF_INITIAL_QUERIES=3

# 最大研究循环次数（默认：2）
# MAX_RESEARCH_LOOPS=2

# 查询生成模型（云端模式下使用）
# QUERY_GENERATOR_MODEL=qwen-plus

# 反思模型（云端模式下使用）
# REFLECTION_MODEL=qwen-plus

# 答案生成模型（云端模式下使用，建议用更强的模型）
# ANSWER_MODEL=qwen-max

# ============================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 根据您的需求选择环境（ENVIRONMENT）
# 3. 配置 API 服务器地址和端口
# 4. 生产环境必须配置 FRONTEND_URL 用于 CORS 安全
# 5. 选择 LLM_PROVIDER（cloud 或 local）并填写对应的 API Key
# 6. 如果使用 Deep Research，必须配置 TAVILY_API_KEY
# 7. 如果使用多模态功能，需要下载 Ollama Vision 模型
#
# 安全提示：
# - 切勿将 .env 文件提交到 Git
# - 生产环境建议使用 127.0.0.1 而非 0.0.0.0
# - 定期轮换 API 密钥
# - 启用 HTTPS（生产环境必须）
# ============================================


